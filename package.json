{
    "name": "gitworker",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "start": "concurrently -n tsc,node \"npm:build:watch\" \"npm:start:watch\"",
        "build": "tsc -p tsconfig.json ",
        "build:watch": "tsc -p tsconfig.json --noCheck --watch --preserveWatchOutput",
        "start:watch": "node --inspect=9943 --watch --enable-source-maps --watch-preserve-output dist/index.js",
        "test": "echo \"Error: no test specified\" && exit 1",
        "dev-gitwebhook": "pm2 start dist/gitwebhook.js --name gitwebhook --node-args=\"--inspect=10004\" --watch \"dist ../shared\" --ignore-watch \"package.json node_modules\""
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/node": "^20.19.39",
        "nodemon": "^3.0.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@acosgames/framework": "^1.0.11",
        "@discordjs/rest": "^0.3.0",
        "acos-json-delta": "^1.0.4",
        "acos-json-encoder": "^2.0.15",
        "aws-sdk": "^2.1204.0",
        "discord-api-types": "^0.30.0",
        "discord.js": "^13.6.0",
        "github-webhook-handler": "^1.0.0",
        "openskill": "^3.1.0",
        "shared": "file:../shared",
        "smee-client": "^1.2.2"
    }
}
